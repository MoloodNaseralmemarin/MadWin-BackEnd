@using MadWin.Core.DTOs.Orders
@using Shop2City.Core.Convertors
@using Shop2City.WebHost.ViewModels.Orders
@model OrderSummaryForAdminViewModel

@{
    int currentPage = Model.CurrentPage;
    int totalPages = Model.TotalPages;
    int pageGroupSize = 5; // تعداد صفحات در هر گروه
    int currentGroup = (currentPage - 1) / pageGroupSize;
    int startPage = currentGroup * pageGroupSize + 1;
    int endPage = Math.Min(startPage + pageGroupSize - 1, totalPages);

    int prevGroupPage = Math.Max(startPage - 1, 1);
    int nextGroupPage = Math.Min(endPage + 1, totalPages);
}

<!-- بخش فیلتر -->
<div class="container mt-3">
    <div class="card border-info shadow-sm">
        <div class="card-header bg-info text-white fs-5">فیلتر جستجو</div>
        <div class="card-body">
            <form method="get">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label for="FromDate" class="form-label">از تاریخ:</label>
                        <input type="date" id="FromDate" name="FromDate" value="@Model.Filter?.FromDate?.ToString("yyyy-MM-dd")" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label for="ToDate" class="form-label">تا تاریخ:</label>
                        <input type="date" id="ToDate" name="ToDate" value="@Model.Filter?.ToDate?.ToString("yyyy-MM-dd")" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label for="OrderId" class="form-label">کد سفارش:</label>
                        <input type="number" id="OrderId" name="OrderId" value="@Model.Filter?.OrderId" class="form-control" placeholder="کد سفارش" />
                    </div>
                    <div class="col-md-3">
                        <label for="FullName" class="form-label">نام مشتری:</label>
                        <input type="text" id="FullName" name="FullName" value="@Model.Filter?.FullName" class="form-control" placeholder="نام کامل" />
                    </div>
                    <div class="col-md-3">
                        <label for="FromPrice" class="form-label">از مبلغ:</label>
                        <input type="number" id="FromPrice" name="FromPrice" value="@Model.Filter?.FromPrice" class="form-control" placeholder="حداقل مبلغ" />
                    </div>
                    <div class="col-md-3">
                        <label for="ToPrice" class="form-label">تا مبلغ:</label>
                        <input type="number" id="ToPrice" name="ToPrice" value="@Model.Filter?.ToPrice" class="form-control" placeholder="حداکثر مبلغ" />
                    </div>
                </div>
                <div class="mt-3 text-end">
                    <button type="submit" class="btn btn-primary">جستجو</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- بخش لیست سفارش‌ها -->
@if (Model.OrderSummary?.Items != null && Model.OrderSummary.Items.Any())
{
    <div class="container mt-4">
        <h4 class="mb-3">لیست سفارش‌ها</h4>
        <div class="row g-3">
            @foreach (var item in Model.OrderSummary.Items)
            {
                <div class="col-sm-6 col-lg-4 col-xl-3">
                    <div class="card h-100 shadow-sm @(item.IsFinaly ? "border-success" : "border-secondary")">
                        <div class="card-body">
                            <h5 class="card-title">کد سفارش: @item.OrderId</h5>
                            <h6 class="card-subtitle mb-2 text-muted">@item.FullName</h6>
                            <p class="card-text"><strong>تاریخ:</strong> @item.CreateDate.ToShamsi()</p>
                            <p class="card-text"><strong>دسته‌بندی:</strong> @item.CategoryGroup</p>
                            <p class="card-text"><strong>ابعاد:</strong> @item.Size</p>
                            <p class="card-text"><strong>تعداد:</strong> @item.Count</p>
                            <p class="card-text"><strong>قیمت پایه:</strong> @item.BasePrice.ToString("N0") تومان</p>
                            <p class="card-text"><strong>قیمت کل:</strong> @item.TotalCost.ToString("N0") تومان</p>
                            <p class="card-text">
                                <strong>وضعیت:</strong>
                                @if (item.IsFinaly)
                                {
                                    <span class="text-success">تسویه شد</span>
                                }
                                else
                                {
                                    <span class="text-danger">تسویه نشده</span>
                                }
                            </p>
                            <div class="d-grid">
                                <button class="btn btn-outline-primary" onclick="showOrderDetails(@item.OrderId)">
                                    <i class="fas fa-eye"></i> مشاهده
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        <nav class="mt-4">
            <ul class="pagination justify-content-center flex-wrap">

                <!-- قبلی -->
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", "Orders", new { PageNumber = currentPage - 1, PageSize = Model.Filter.PageSize, FullName = Model.Filter.FullName, OrderId = Model.Filter.OrderId, FromDate = Model.Filter.FromDate?.ToString("yyyy-MM-dd"), ToDate = Model.Filter.ToDate?.ToString("yyyy-MM-dd"), FromPrice = Model.Filter.FromPrice, ToPrice = Model.Filter.ToPrice })">قبلی</a>
                </li>

                <!-- گروه قبلی -->
                <li class="page-item @(startPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", "Orders", new { PageNumber = prevGroupPage, PageSize = Model.Filter.PageSize, FullName = Model.Filter.FullName, OrderId = Model.Filter.OrderId, FromDate = Model.Filter.FromDate?.ToString("yyyy-MM-dd"), ToDate = Model.Filter.ToDate?.ToString("yyyy-MM-dd"), FromPrice = Model.Filter.FromPrice, ToPrice = Model.Filter.ToPrice })">«</a>
                </li>

                <!-- شماره صفحات -->
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", "Orders", new { PageNumber = i, PageSize = Model.Filter.PageSize, FullName = Model.Filter.FullName, OrderId = Model.Filter.OrderId, FromDate = Model.Filter.FromDate?.ToString("yyyy-MM-dd"), ToDate = Model.Filter.ToDate?.ToString("yyyy-MM-dd"), FromPrice = Model.Filter.FromPrice, ToPrice = Model.Filter.ToPrice })">@i</a>
                    </li>
                }

                <!-- گروه بعدی -->
                <li class="page-item @(endPage == totalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", "Orders", new { PageNumber = nextGroupPage, PageSize = Model.Filter.PageSize, FullName = Model.Filter.FullName, OrderId = Model.Filter.OrderId, FromDate = Model.Filter.FromDate?.ToString("yyyy-MM-dd"), ToDate = Model.Filter.ToDate?.ToString("yyyy-MM-dd"), FromPrice = Model.Filter.FromPrice, ToPrice = Model.Filter.ToPrice })">»</a>
                </li>

                <!-- بعدی -->
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", "Orders", new { area = "Admin", PageNumber = currentPage + 1, PageSize = Model.Filter.PageSize, FullName = Model.Filter.FullName, OrderId = Model.Filter.OrderId, FromDate = Model.Filter.FromDate?.ToString("yyyy-MM-dd"), ToDate = Model.Filter.ToDate?.ToString("yyyy-MM-dd"), FromPrice = Model.Filter.FromPrice, ToPrice = Model.Filter.ToPrice })">بعدی</a>
                </li>
            </ul>
        </nav>
    </div>
}
else
{
    <div class="alert alert-warning mt-4 text-center">هیچ سفارشی یافت نشد.</div>
}


<div class="modal fade" id="orderDetailsModal" tabindex="-1" aria-labelledby="orderDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="orderDetailsModalLabel">جزئیات سفارش</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="بستن"></button>
            </div>
            <div class="modal-body">
                <div class="text-center">
                    <div class="spinner-border" role="status" id="orderDetailsLoader" style="display: none;"></div>
                </div>
                <div id="orderDetailsContent"></div>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <script>
        function showOrderDetails(orderId) {
                    console.log(bootstrap);
        console.log(typeof bootstrap.Modal);

            // نمایش لودر
            document.getElementById("orderDetailsLoader").style.display = "block";
            document.getElementById("orderDetailsContent").innerHTML = "";

            fetch('/Admin/Orders/ShowOrderDetails?id=' + orderId)
                .then(response => response.text())
                .then(html => {
                    document.getElementById("orderDetailsLoader").style.display = "none";
                    document.getElementById("orderDetailsContent").innerHTML = html;
                    var myModal = new bootstrap.Modal(document.getElementById('orderDetailsModal'));
                    myModal.show();
                })
                .catch(error => {
                    document.getElementById("orderDetailsContent").innerHTML = "خطا در بارگذاری اطلاعات";
                    console.error(error);
                });
        }
    </script>

}