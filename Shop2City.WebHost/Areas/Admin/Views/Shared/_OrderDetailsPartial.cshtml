@using MadWin.Core.Entities.CurtainComponents
@model IEnumerable<CurtainComponentDetail>

    <div class="table-responsive-md d-none d-md-block">
        <table class="table table-bordered table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th scope="col">نام قطعه</th>
                    <th scope="col">قیمت</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-wrap">@item.CurtainComponent?.Name</td>
                        <td>@string.Format(new System.Globalization.CultureInfo("fa-IR"), "{0:N0}", item.UnitCost)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- کارت‌ها: نمایش در موبایل (کمتر از md) -->
    <div class="d-md-none">
        @foreach (var item in Model)
        {
            <div class="card mb-2 shadow-sm">
                <div class="card-body p-2">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="fw-semibold small text-truncate" style="max-width:65%;">
                            @item.CurtainComponent?.Name
                        </div>
                        <div class="text-end small">
                            <div class="text-muted small">قیمت</div>
                            <div class="fw-bold">
                                @string.Format(new System.Globalization.CultureInfo("fa-IR"), "{0:N0}", item.UnitCost)
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>