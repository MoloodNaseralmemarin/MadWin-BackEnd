@using MadWin.Core.DTOs.DisCounts
@model AddDiscountForAdminViewModel
@{
}
<div class="container" dir="rtl">
    <div class="card my-3">
        <div class="card-body">
            <h4 class="card-title mb-3">ثبت کد تخفیف جدید</h4>

            <form method="post" class="row g-3">
                <!-- نوع سفارش -->
                <div class="col-12">
                    <label class="form-label">نوع سفارش</label>
                    <select asp-for="Item" class="form-select" aria-label="نوع سفارش">
                        <option value="O">سفارش با اندازه دلخواه</option>
                        <option value="F">سفارش آماده</option>
                    </select>
                    <span class="text-danger" asp-validation-for="Item"></span>
                </div>

                <!-- درصد، کد، تعداد قابل استفاده -->
                <div class="col-12 col-md-4">
                    <label asp-for="DiscountCode" class="form-label"></label>
                    <input type="number" step="0.01" min="0" class="form-control" asp-for="DiscountCode" id="DiscountCode" />
                    <span class="text-danger" asp-validation-for="DiscountCode"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="Percentage" class="form-label"></label>
                    <input type="text" class="form-control" asp-for="Percentage" />
                    <span class="text-danger" asp-validation-for="Percentage"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="UseableCount" class="form-label"></label>
                    <input type="number" min="0" class="form-control" asp-for="UseableCount" />
                    <span class="text-danger" asp-validation-for="UseableCount"></span>
                </div>

                <!-- تاریخ شروع و پایان -->
                <div class="row">
                    <div class="col-md-6">
                        <label asp-for="StartDate"></label>
                        <input id="startDate" class="form-control" name="startDate" />
                        <span class="text-danger" asp-validation-for="StartDate"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ExpiryDate"></label>
                        <input id="expiryDate" class="form-control" name="expiryDate" />
                        <span class="text-danger" asp-validation-for="ExpiryDate"></span>
                    </div>
                </div>



                <!-- دکمه‌ها -->
                <div class="col-12 d-flex gap-2 justify-content-start">
                    <input type="submit" class="btn btn-success" value="ذخیره اطلاعات" />
                    <a  class="btn btn-outline-info">پاک کردن</a>
                    <a  class="btn btn-primary" data-bs-toggle="tooltip" title="مشاهده لیست محصولات درج شده">بازگشت به فهرست</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts{
    <script>
        $(document).ready(function () {
              $('#startDate').persianDatepicker(
                  {
                      observer: true,
                      format: 'YYYY/MM/DD',
                      Datepicker: '#startDate',
                      autoClose: true,
                      minDate: new persianDate().unix()

                  });
              $('#expiryDate').persianDatepicker(
                  {
                      observer: true,
                      format: 'YYYY/MM/DD',
                      Datepicker: '#expiryDate',
                      autoClose: true
                  });

          });
        $(document).ready(function () {
            $("#DiscountCode").on("blur", function () {
                let code = $(this).val().trim();

                if (code === "") {
                    return; // اگه خالی بود، هیچ کاری نکن
                }

                $.ajax({
                    url: '/DisCounts/IsExistDisCountCode',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ code: code }),
                    success: function (response) {
                        if (response.isDuplicate) {
                            toastr.error("کد تخفیف تکراری است!", "خطا");
                        } else {
                            toastr.success("کد تخفیف معتبر است ", "موفقیت");
                        }
                    },
                    error: function (xhr) {
                        toastr.warning("خطا در برقراری ارتباط با سرور", "هشدار");
                        console.log("خطا: ", xhr.responseText);
                    }
                });
            });
        });
    </script>
}