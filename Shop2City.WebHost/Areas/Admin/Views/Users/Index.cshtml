@using Azure.Core
@using MadWin.Core.DTOs.Users
@using Shop2City.Core.Convertors
@model UserForAdminViewModel
@{
    ViewBag.Title = "لیست کاربران";
    var currentFilter = (Context.Request.Query["filterFirstName"].ToString() ?? "");
}

<div class="container-fluid my-3">
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">لیست کاربران</h5>
            <a asp-area="Admin" asp-controller="Users" asp-action="Create" class="btn btn-success btn-sm">
                <i class="fa fa-plus"></i> ثبت کاربر جدید
            </a>
        </div>

        <div class="card-body">
            <!-- فرم جستجو -->
            <form class="mb-3">
                <div class="row g-2">
                    <div class="col-12 col-md-8">
                        <input type="text" class="form-control"
                               name="filterFirstName"
                               placeholder="نام را وارد کنید..."
                               value="@currentFilter" />
                    </div>
                    <div class="col-12 col-md-4 d-flex">
                        <button type="submit" class="btn btn-primary flex-fill me-2">
                            <i class="fa fa-search"></i>
                        </button>
                        <a asp-area="Admin" asp-controller="Users" asp-action="Index"
                           class="btn btn-secondary flex-fill">
                            <i class="fa fa-refresh"></i>
                        </a>
                    </div>
                </div>
            </form>

            <!-- نمایش به صورت جدول (فقط دسکتاپ و تبلت) -->
            <div class="table-responsive-md d-none d-md-block">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>شناسه</th>
                            <th>نام کامل</th>
                            <th>شماره همراه</th>
                            <th>تاریخ ثبت‌نام</th>
                            <th>دستورات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.users)
                        {
                            <tr>
                                <td>@user.Id</td>
                                <td>@user.FirstName @user.LastName</td>
                                <td>@user.CellPhone</td>
                                <td>@user.CreateDate.ToShamsi()</td>
                                <td>
                                    <div class="btn-group">
                                        <a href="@Url.Action("Edit", "Users", new { area = "Admin", id = user.Id })"
                                           class="btn btn-warning btn-sm">
                                            <i class="fa fa-edit"></i>
                                        </a>
                                        <a href="@Url.Action("Delete", "Users", new { area = "Admin", id = user.Id })"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('آیا مطمئن هستید؟');">
                                            <i class="fa fa-remove"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- نمایش به صورت کارت (فقط موبایل) -->
            <div class="d-block d-md-none">
                <div class="row g-2">
                    @foreach (var user in Model.users)
                    {
                        <div class="col-12">
                            <div class="card shadow-sm">
                                <div class="card-body">
                                    <h6 class="card-title">@user.FirstName @user.LastName</h6>
                                    <p class="card-text mb-1"><strong>شناسه:</strong> @user.Id</p>
                                    <p class="card-text mb-1"><strong>شماره همراه:</strong> @user.CellPhone</p>
                                    <p class="card-text mb-1"><strong>تاریخ ثبت‌نام:</strong> @user.CreateDate.ToShamsi()</p>
                                    <div class="d-flex justify-content-end mt-2">
                                        <a href="@Url.Action("Edit", "Users", new { area = "Admin", id = user.Id })"
                                           class="btn btn-warning btn-sm me-2">
                                            <i class="fa fa-edit"></i>
                                        </a>
                                        <a href="@Url.Action("Delete", "Users", new { area = "Admin", id = user.Id })"
                                           class="btn btn-danger btn-sm"
                                           onclick="return confirm('آیا مطمئن هستید؟');">
                                            <i class="fa fa-remove"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- صفحه‌بندی -->
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm flex-wrap justify-content-center mt-3">
                    @for (var i = 1; i <= Model.countPage; i++)
                    {
                        <li class="page-item @(i == Model.currentPage ? "active" : "")">
                            <a class="page-link"
                               href="@Url.Action("Index", "Users",
                                                              new { area = "Admin", pageId = i, filterFirstName = currentFilter })">
                            @i
                        </a>
                    </li>
                                        }
                </ul>
            </nav>
        </div>
    </div>
</div>

