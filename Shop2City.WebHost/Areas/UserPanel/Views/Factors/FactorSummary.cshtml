@using MadWin.Core.DTOs.Fators
@model FactorSummaryViewModel

@{
    var factorSummary = Model.FactorSummaryForAdmin;
    var factor = factorSummary.FactorSummary.FirstOrDefault();
    var factorId = factor.FactorId;
    var createDate = factor.CreateDate;
    var totalPrice = factor.SubTotal; // یا TotalPrice اگه پراپرتی‌ات اینطوره
}

<div class="container my-4">

    <!-- مسیر صفحه (Breadcrumb) -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">
                    <i class="fa fa-home"></i> خانه
                </a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Factors" asp-action="Index">
                    <i class="fa fa-file-invoice"></i> فاکتورها
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                <i class="fa fa-shopping-cart"></i> سبد خرید
            </li>
        </ol>
    </nav>
    <div class="row">
        <partial name="_SideBar" />
        <div class="col-lg-9">
            <!-- کارت سبد خرید -->
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fa fa-shopping-basket"></i>خلاصه فاکتور</h5>
                    <span class="badge bg-light text-dark">شماره فاکتور: @factorId</span>
                </div>

                <div class="card-body">
                    @if (factor != null && factor.FactorDetails.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th><input type="checkbox" id="selectAll" /></th>
                                        <th>محصول</th>
                                        <th>قیمت واحد</th>
                                        <th>تعداد</th>
                                        <th>قیمت کل</th>
                                        <th>عملیات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var detail in factor.FactorDetails)
                                    {
                                        <tr>
                                            <td>
                                            <td><input type="checkbox" class="delete-checkbox" value="@detail.Id" /></td>
                                            </td>
                                            <td>@detail.ProductTitle</td>
                                            <td>@detail.Price.ToString("N0") ریال</td>
                                            <td>@detail.Quantity</td>
                                            <td>@detail.TotalPrice.ToString("N0") ریال</td>
                                            <td class="text-center align-middle">
                                                <a onclick="removeItems(@detail.Id)" style="cursor:pointer;">
                                                    <i class="fa fa-trash text-danger"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tr>
                                    <td colspan="6">
                                        <button class="btn btn-danger" onclick="removeItems(@factorId)">
                                            <i class="fa fa-trash"></i> حذف انتخاب‌شده‌ها
                                        </button>
                                    </td>
                                </tr>
                                <!-- بخش انتخاب روش ارسال -->
                                <tr>
                                    <td colspan="2"><strong>روش ارسال:</strong></td>
                                    <td colspan="4">
                                        <div class="radio-groups">
                                            @foreach (var delivery in Model.DeliveryMethods)
                                            {
                                                <input type="radio" name="selection" value="@delivery.DeliveryId" id="delivery_@delivery.DeliveryId" />
                                                <label for="delivery_@delivery.DeliveryId">@delivery.Name</label>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                <!-- بخش کد تخفیف -->
                                <tr>
                                    <td colspan="2"><strong>کد تخفیف:</strong></td>
                                    <td colspan="4" class="mt-2">
                                        <input type="hidden" id="factorId" value="@factorId" />
                                        <input type="text" id="discountCode" class="form-control" />
                                        <button id="applyDiscountBtn" class="btn btn-primary w-100 py-2">
                                            اعمال کد تخفیف
                                        </button>
                                    </td>
                                </tr>

                            </table>
                            <div class="d-flex justify-content-center mt-4">
                                <div class="w-100" style="max-width: 500px;">
                                    <table class="table table-bordered text-center">
                                        <tr>
                                            <td><strong>جمع کل قبل از تخفیف :</strong></td>
                                            <td id="SubtotalPrice">@totalPrice.ToString("N0")</td>
                                        </tr>
                                        <tr>
                                            <td><strong>مبلغ تخفیف :</strong></td>
                                            <td><span id="disTotal">0</span></td>
                                        </tr>
                                        <tr>
                                            <td><strong>هزینه ارسال و بسته‌بندی :</strong></td>
                                            <td><span id="deliveryPrice">0</span></td>
                                        </tr>
                                        <tr class="h4 text-primary">
                                            <td colspan="2"><strong>مبلغ قابل پرداخت :</strong> <span id="sumOrder">0</span></td>
                                        </tr>
                                        <tr>
                                            <td colspan="2">
                                                <button class="btn btn-success w-100 py-2" id="postButton" disabled>
                                                    پرداخت آنلاین - <span id="sumOrderBtn">0</span>
                                                </button>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div class="mt-3 d-flex justify-content-between">
                            <a asp-action="Checkout" asp-route-factorId="@factorId" class="btn btn-success">
                                <i class="fa fa-credit-card"></i> ادامه خرید
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning text-center" role="alert">
                            <i class="fa fa-info-circle"></i> سبد خرید شما خالی است.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            // 🔹 تابع تبدیل متن عددی به عدد
            function parseNumber(text) {
                return Number(text.replace(/,/g, '').replace(/[^\d.-]/g, '')) || 0;
            }

            // 🔹 تابع محاسبه مبلغ نهایی
            function updateTotal() {
                const subtotal = parseNumber($("#SubtotalPrice").text());
                const delivery = parseNumber($("#deliveryPrice").text());
                const discount = parseNumber($("#disTotal").text());
                const total = subtotal - discount + delivery;

                $("#sumOrder").text(total.toLocaleString());
                $("#sumOrderBtn").text(total.toLocaleString());
            }

            updateTotal();

            // ✅ تعریف تابع در سطح global تا از onclick در HTML کار کند
            window.removeItems = function (selectedIds) {
                if (!selectedIds || selectedIds.length === 0) {
                    toastr.warning('هیچ موردی انتخاب نشده است.');
                    return;
                }

                // اگر فقط یک عدد باشد، تبدیل به آرایه شود
                if (!Array.isArray(selectedIds)) {
                    selectedIds = [selectedIds];
                }

                $.ajax({
                    url: '/Factors/RemoveItemsByFactor',
                    type: 'POST',
                    data: { factorDetailIds: selectedIds },
                    traditional: true,
                    success: function (response) {
                        if (response.success) {
                            toastr.success("آیتم‌ها با موفقیت حذف شدند.");
                            location.reload();
                        } else {
                            toastr.error(response.message || "خطا در حذف آیتم‌ها.");
                        }
                    },
                    error: function () {
                        toastr.error("مشکلی در برقراری ارتباط با سرور رخ داد.");
                    }
                });
            };

            // 🟦 انتخاب همه چک‌باکس‌ها
            $("#selectAll").on("change", function () {
                $(".delete-checkbox").prop("checked", this.checked);
            });

            // 🟥 حذف انتخاب‌شده‌ها (دکمه پایین جدول)
            $(document).on("click", "#deleteSelected", function () {
                const selectedIds = $(".delete-checkbox:checked").map(function () {
                    return $(this).val();
                }).get();

                removeItems(selectedIds);
            });

            // 🟩 تغییر روش ارسال
            $("input:radio[name=selection]").on("change", function () {
                const selectedDeliveryId = $(this).val();
                $("#postButton").prop("disabled", false);

                $.ajax({
                    type: "GET",
                    url: "/Home/GetDeliveryPrice",
                    data: { deliveryId: selectedDeliveryId },
                    success: function (result) {
                        if (result.success) {
                            $("#deliveryPrice").text(result.price.toLocaleString());
                            updateTotal();
                        } else {
                            toastr.error(result.message || "خطا در دریافت هزینه ارسال");
                        }
                    },
                    error: function () {
                        toastr.error("خطا در ارتباط با سرور برای دریافت هزینه ارسال");
                    }
                });
            });

            // 🟨 اعمال کد تخفیف
            $("#applyDiscountBtn").click(function (e) {
                e.preventDefault();

                const factorId = $("#factorId").val();
                const discountCode = $("#discountCode").val().trim();

                if (!discountCode) {
                    toastr.warning("لطفاً کد تخفیف را وارد کنید.");
                    return;
                }

                $.ajax({
                    url: '/Factors/UseDiscountForFactor',
                    type: 'GET',
                    data: { factorId, discountCode },
                    success: function (response) {
                        if (response.success) {
                            $("#disTotal").text(response.discountAmount.toLocaleString());
                            updateTotal();
                            toastr.success(response.message || "تخفیف با موفقیت اعمال شد.");
                        } else {
                            toastr.error(response.message || "کد تخفیف معتبر نیست.");
                        }
                    },
                    error: function () {
                        toastr.error("خطا در اعمال کد تخفیف");
                    }
                });
            });

            // 🟩 پرداخت آنلاین
            $('#postButton').click(function () {
                const $btn = $(this);
                $btn.prop('disabled', true);

                const sumOrder = parseNumber($("#sumOrder").text());
                const factorId = parseInt($('#factorId').val());
                const selectedDelivery = parseInt($('input[name="selection"]:checked').val());

                if (!selectedDelivery) {
                    toastr.warning("لطفاً روش ارسال را انتخاب کنید.");
                    $btn.prop('disabled', false);
                    return;
                }

                if (!factorId || isNaN(factorId)) {
                    toastr.error("شناسه فاکتور نامعتبر است.");
                    $btn.prop('disabled', false);
                    return;
                }

                const dataToSend = {
                    sumOrder,
                    invoiceId: factorId,
                    deliveryId: selectedDelivery,
                    source: 'factor'
                };

                $.ajax({
                    url: '/Payment/ProcessPayment',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(dataToSend),
                    xhrFields: { withCredentials: true },
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() || ''
                    },
                    success: function (response) {
                        if (response.success) {
                            window.location.href = response.redirectUrl;
                        } else {
                            toastr.error(response.message || "پرداخت موفق نبود.");
                        }
                    },
                    error: function (xhr) {
                        if (xhr.status === 401) {
                            toastr.error("برای پرداخت باید وارد حساب کاربری شوید.");
                            window.location.href = "/Account/Login";
                        } else if (xhr.status === 403) {
                            toastr.error("دسترسی غیرمجاز.");
                        } else {
                            toastr.error("خطایی در ارسال درخواست رخ داد.");
                        }
                    },
                    complete: function () {
                        $btn.prop('disabled', false);
                    }
                });
            });
        });
    </script>
}



