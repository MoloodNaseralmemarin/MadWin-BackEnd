@using MadWin.Core.DTOs.Products
@model IList<ShowProductListItemViewModel>

<div class="container my-4">
    <div class="d-flex flex-row flex-wrap flex-sm-nowrap gap-3 pb-3 overflow-auto">
        @if (Model.Count > 0)
        {
            @foreach (var item in Model)
            {
                <div class="item-box shadow-sm rounded-3 bg-white"
                     style="flex: 0 0 auto; width: 100%; max-width: 250px;">
                    @await Html.PartialAsync("_ProductBox", item)
                </div>
            }
        }
    </div>
</div>
