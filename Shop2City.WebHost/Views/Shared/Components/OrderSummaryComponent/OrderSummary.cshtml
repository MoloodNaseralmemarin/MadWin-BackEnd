@using MadWin.Core.DTOs.Orders
@using Shop2City.Core.Convertors
@using Shop2City.WebHost.ViewModels.Orders
@model OrderSummaryPageViewModel


<div class="container mt-3">
    <h4 class="mb-3">سفارشات امروز <span class="badge bg-primary">@Model.OrderSummary.TotalCount</span></h4>

    @if (Model.OrderSummary.Items.Any())
    {
        <!-- جدول دسکتاپ -->
        <div class="table-responsive d-none d-md-block">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>کد</th>
                        <th>تاریخ</th>
                        <th>نام مشتری</th>
                        <th>دسته‌بندی</th>
                        <th>اندازه</th>
                        <th>تعداد</th>
                        <th>قیمت</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var order in Model.OrderSummary.Items)
                {
                    <tr>
                        <td>@order.OrderId</td>
                        <td>@order.CreateDate.ToShamsi()</td>
                        <td>@order.FullName</td>
                        <td>@order.CategoryGroup</td>
                        <td>@order.Size</td>
                        <td>@order.Count</td>
                        <td>@order.PriceWithFee.ToString("N0") ریال</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <!-- کارت موبایل -->
        <div class="d-block d-md-none">
            @foreach (var order in Model.OrderSummary.Items)
            {
                <div class="card mb-3 shadow-sm border-0">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center">
                        <span>@order.CategoryGroup</span>
                        <small>@order.CreateDate.ToShamsi()</small>
                    </div>
                    <div class="card-body">
                        <div class="row mb-1">
                            <div class="col-6"><strong>کد:</strong> @order.OrderId</div>
                            <div class="col-6"><strong>نام مشتری:</strong> @order.FullName</div>
                        </div>
                        <div class="row mb-1">
                            <div class="col-6"><strong>اندازه:</strong> @order.Size</div>
                            <div class="col-6"><strong>تعداد:</strong> @order.Count</div>
                        </div>
                        <div class="row mb-1">
                            <div class="col-12"><strong>قیمت:</strong> @order.PriceWithFee.ToString("N0") ریال</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-warning">هیچ سفارشی برای امروز ثبت نشده است.</div>
    }

    <hr />

    <h5>روش‌های ارسال</h5>
    @if (Model.DeliveryMethods.Any())
    {
        <div class="radio-groups">
            @foreach (var delivery in Model.DeliveryMethods)
            {
                <label class="form-check-label me-3">
                    <input type="radio" name="deliveryMethod" value="@delivery.DeliveryId" class="form-check-input" />
                    @delivery.Name
                </label>
            }
        </div>
    }
    else
    {
        <div class="text-muted">هیچ روش ارسالی ثبت نشده است.</div>
    }
</div>


@section Scripts
{
    <script>
        function updateTotal() {
            let subtotalText = $("#SubtotalPrice").text();
            let subtotal = Number(subtotalText.replace(/[^\d]/g, ''));

            let deliveryText = $("#deliveryPrice").text();
            let delivery = Number(deliveryText.replace(/[^\d]/g, ''));

            let disTotalText = $("#disTotal").text();
            let disTotal = Number(disTotalText.replace(/[^\d]/g, ''));

            let total = subtotal - disTotal + delivery;
            if (total < 0) total = 0;

            $("#sumOrder").text(total.toLocaleString());
        }

        let selectedDeliveryId = null;

        $(document).ready(function () {
            updateTotal();

            $("input:radio[name=selection]").on("change", function () {
                selectedDeliveryId = $(this).val();
                $("input:radio[name=selection]").each(function () {
                    $(this).prop("checked", $(this).val() === selectedDeliveryId);
                });
                $("#postButton").prop("disabled", false);

                $.ajax({
                    type: "GET",
                    url: "/Home/GetDeliveryPrice",
                    data: { deliveryId: selectedDeliveryId },
                    success: function (result) {
                        if (result.success) {
                            $("#deliveryPrice").text(result.price.toLocaleString());
                            updateTotal();
                        }
                    },
                    error: function () {
                        alert("خطا در دریافت هزینه ارسال");
                    }
                });
            });

            // اعمال کد تخفیف - دسکتاپ
            $("#applyDiscountBtn").click(function (e) {
                e.preventDefault();

                var orderId = $(".orderId").first().val();
                var discountCode = $(".discountCode").first().val().trim();

                if (!discountCode) {
                    $("#discountMessage").text("لطفاً کد تخفیف را وارد کنید.");
                    return;
                }

                $.ajax({
                    type: "POST",
                    url: "/Home/ApplyDiscount",
                    data: { orderId: orderId, discountCode: discountCode },
                    success: function (result) {
                        if (result.success) {
                            $("#disTotal").text(result.discountAmount.toLocaleString());
                            $("#discountMessage").text("کد تخفیف با موفقیت اعمال شد.").removeClass("text-danger").addClass("text-success");
                            updateTotal();
                        } else {
                            $("#discountMessage").text(result.message).removeClass("text-success").addClass("text-danger");
                            $("#disTotal").text("0");
                            updateTotal();
                        }
                    },
                    error: function () {
                        $("#discountMessage").text("خطا در اعمال کد تخفیف. لطفاً دوباره تلاش کنید.").removeClass("text-success").addClass("text-danger");
                        $("#disTotal").text("0");
                        updateTotal();
                    }
                });
            });

            // اعمال کد تخفیف - موبایل
            $("#applyDiscountBtnMobile").click(function (e) {
                e.preventDefault();

                var orderId = $(".orderId").last().val();
                var discountCode = $(".discountCode").last().val().trim();

                if (!discountCode) {
                    $("#discountMessageMobile").text("لطفاً کد تخفیف را وارد کنید.");
                    return;
                }

                $.ajax({
                    type: "POST",
                        url: "/Home/ApplyDiscount",
                        data: { orderId: orderId, discountCode: discountCode },
                        success: function (result) {
                            if (result.success) {
                                $("#disTotal").text(result.discountAmount.toLocaleString());
                                $("#discountMessageMobile").text("کد تخفیف با موفقیت اعمال شد.").removeClass("text-danger").addClass("text-success");
                                updateTotal();
                            } else {
                                $("#discountMessageMobile").text(result.message).removeClass("text-success").addClass("text-danger");
                                $("#disTotal").text("0");
                                updateTotal();
                            }
                        },
                    error: function () {
                        $("#discountMessageMobile").text("خطا در اعمال کد تخفیف. لطفاً دوباره تلاش کنید.").removeClass("text-success").addClass("text-danger");
                        $("#disTotal").text("0");
                        updateTotal();
                    }
                });
            });
        });
    </script>
}
