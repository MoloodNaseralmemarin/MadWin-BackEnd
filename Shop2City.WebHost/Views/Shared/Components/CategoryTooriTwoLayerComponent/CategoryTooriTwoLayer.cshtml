@using MadWin.Core.DTOs.Products
@model IList<ShowProductListItemViewModel>

<div class="container my-4">
    <div class="d-flex flex-row flex-nowrap overflow-auto gap-3 pb-3">
        @if (Model.Count > 0)
        {
            @foreach (var item in Model)
            {
                <div class="flex-shrink-0" style="width: 100%;">
                    <div class="card" style="min-width: 150px; max-width: 250px;">
                        @await Html.PartialAsync("_ProductBox", item)
                    </div>
                </div>
            }
        }
    </div>
</div>




