
@using Shop2City.WebHost.ViewModels.Orders
@model OrderViewModel
@{
  
}
<div class="modal fade" id="customSizeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <form id="customSizeForm" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">سفارش با اندازه دلخواه</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <!-- دسته بندی -->
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label">دسته</label>
                            <select class="form-select" id="CategoryId" required>
                                <option value="">انتخاب کنید</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label">زیر دسته</label>
                            <select class="form-select" id="SubCategoryId" required></select>
                        </div>
                    </div>

                    <!-- ابعاد -->
                    <div class="row g-3 mt-2">
                        <div class="col-6">
                            <label class="form-label">ارتفاع (cm)</label>
                            <input type="number" id="Height" class="form-control" required>
                        </div>
                        <div class="col-6">
                            <label class="form-label">عرض کل (cm)</label>
                            <input type="number" id="totalWidth" class="form-control" required>
                        </div>
                    </div>

                    <!-- تقسیم بندی -->
                    <div class="mt-3">
                        <label class="form-label">تقسیم‌بندی</label>
                        <div class="d-flex flex-wrap gap-2">
                            <label class="btn btn-outline-primary">
                                <input type="radio" name="division" value="2-equal" onclick="updateInputs(2,'equal')"> ۲ مساوی
                            </label>
                            <label class="btn btn-outline-primary">
                                <input type="radio" name="division" value="2-unequal" onclick="updateInputs(2,'unequal')"> ۲ نامساوی
                            </label>
                            <label class="btn btn-outline-primary">
                                <input type="radio" name="division" value="3-equal" onclick="updateInputs(3,'equal')"> ۳ مساوی
                            </label>
                            <label class="btn btn-outline-primary">
                                <input type="radio" name="division" value="3-unequal" onclick="updateInputs(3,'unequal')"> ۳ نامساوی
                            </label>
                        </div>
                    </div>

                    <div class="mt-3" id="width-inputs">
                        <label class="form-label">اندازه‌ها</label>
                        <div id="input-container"></div>
                    </div>

                    <div class="mt-3">
                        <label class="form-label">تعداد</label>
                        <input type="number" id="Count" class="form-control" min="1" required>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary" id="submitOrder" disabled>ثبت</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const $form = $("#customSizeForm");
    const $submit = $("#submitOrder");

    function checkForm(){
      let valid = true;
      $form.find("input[required], select[required]").each(function(){
        if(!$(this).val()) valid = false;
      });

      let sum = 0, total = parseFloat($("#totalWidth").val())||0;
      $(".width-input").each(function(){ sum += parseFloat($(this).val())||0; });
      if($(".width-input").length && sum !== total) valid = false;

      $submit.prop("disabled", !valid);
    }

    $form.on("input change", "input, select", checkForm);

    function updateInputs(count, type){
      const totalWidth = parseFloat($("#totalWidth").val());
      if(!totalWidth) return;

      const container = $("#input-container");
      container.empty();

      const labels = (count===2)? ["راست","چپ"] : ["راست","وسط","چپ"];

      for(let i=0; i<count; i++){
        container.append(`
          <div class="mb-2">
            <label class="form-label">${labels[i]}</label>
            <input type="number" class="form-control width-input"
              ${type==="equal" ? "readonly" : ""}
              value="${type==="equal" ? (totalWidth/count).toFixed(0) : ""}">
          </div>
        `);
      }
      checkForm();
    }
</script>

