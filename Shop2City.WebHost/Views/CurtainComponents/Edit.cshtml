@using Shop2City.WebHost.ViewModels.CurtainComponents
@model CurtainComponentEditViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <h2 class="mb-4">ویرایش @Model.Name/h2>

            <form asp-action="Edit" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <!-- Name -->
                    <div class="col-12 col-md-6">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" type="text" required />
                        <div class="invalid-feedback">
                            <span asp-validation-for="Name"></span>
                        </div>
                    </div>

                    <!-- Cost -->
                    <div class="col-12 col-md-6">
                        <label asp-for="Cost" class="form-label"></label>
                        <input asp-for="Cost" class="form-control" type="text" required />
                        <div class="invalid-feedback">
                            <span asp-validation-for="Cost"></span>
                        </div>
                    </div>
                    <!-- Buttons -->
                    <div class="col-12 d-flex justify-content-end mt-2">
                        <a asp-action="Index" class="btn btn-secondary me-2">انصراف</a>
                        <button type="submit" class="btn btn-success">ثبت</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
